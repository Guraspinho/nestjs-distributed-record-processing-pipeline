{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "apps/optio-technical-assignment/src",
	"compilerOptions": {
		"deleteOutDir": true,
		"webpack": true,
		"tsConfigPath": "apps/optio-technical-assignment/tsconfig.app.json"
	},
	"monorepo": true,
	"root": "apps/optio-technical-assignment",
	"projects": {
		"api-gateway": {
			"type": "application",
			"root": "apps/api-gateway",
			"entryFile": "main",
			"sourceRoot": "apps/api-gateway/src",
			"compilerOptions": {
				"tsConfigPath": "apps/api-gateway/tsconfig.app.json"
			}
		}
	}
}
